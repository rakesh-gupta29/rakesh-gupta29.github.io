---
interface Props {
  title: string;
  cover: string;
  id: string;
  slug: string;
  author: string;
  createdAt: string;
  desc: string;
}
const { data } = Astro.props;
const { title, cover, id, author, createdAt, desc, slug } = data;
---

<article
  class="grid lg:grid-cols-8 gap-x-6 gap-y-3 border-1 border-solid border-gray group"
>
  <div class="col-start-1 lg:col-end-4 h-64 md:h-72 2xl:h-80 lg:p-3">
    <img
      src={cover}
      alt={title}
      class="h-full w-full object-cover object-center"
    />
  </div>
  <div
    class="lg:col-end-9 lg:col-start-4 px-3 pt-1 pb-10 md:pb-6 lg:pb-10 md:py-6 lg:py-8 xl:py-10"
  >
    <h4 class="font-satoshi-semibold text-dark pb-2">{title}</h4>
    <h6 class="text-dark text-opacity-80 font-satoshi max-w-lg">{desc}</h6>
    <div
      class="flex mr-auto flex-nowrap items-center mt-4 md:mt-6 lg:mt-8 gap-2"
    >
      <a
        target="_blank"
        href={slug}
        aria-label={` Visit ${title} website`}
        class="font-satoshi-bold pb-2 relative text-lg flex flex-nowrap items-end gap-2"
      >
        Read More
        <div
          class="absolute top-auto bottom-0 left-0 bg-dark w-0 group-hover:w-full transition-all duration-200 ease-in-out h-[1px]"
        >
        </div>
      </a>
      <img
        src="/img/externalLink.svg"
        alt="external link"
        class="h-6 transition-all duration-200 ease-in-out group-focus:opacity-100 mb-2"
      />
    </div>
  </div>
</article>
