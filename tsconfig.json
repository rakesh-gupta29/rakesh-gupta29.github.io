{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@atoms/*": [
        "src/components/atoms/*"
      ],
      "@molecules/*": [
        "src/components/molecules/*"
      ],
      "@organisms/*": [
        "src/components/organisms/*"
      ],
      "@layouts/*": [
        "src/layouts/*"
      ],
      "@views/*": [
        "src/components/views/*"
      ],
      "@static/*": [
        "src/static/*"
      ],
    },
  }
}